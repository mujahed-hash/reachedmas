12:["$","p",null,{"children":[["$","strong",null,{"children":"Interaction logs"}]," are retained for 90 days, then purged automatically.",["$","strong",null,{"children":"Account data"}]," persists until you delete your account.",["$","strong",null,{"children":"IP hashes"}]," are non-reversible; the original IP cannot be recovered."]}]
