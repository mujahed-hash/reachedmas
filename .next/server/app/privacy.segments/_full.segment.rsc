7:["$","p",null,{"children":[["$","strong",null,{"children":"Phone numbers:"}]," If you provide a phone number, it is encrypted using ",["$","strong",null,{"children":"AES-256-GCM"}]," before storage. We never store your phone number in plain text."]}]
8:["$","p",null,{"children":[["$","strong",null,{"children":"Scan data:"}]," When someone scans your tag, we log a one-way hash of their IP address (not the IP itself), browser user-agent, and an approximate city derived from their IP (e.g., “Austin, TX”). We do ",["$","strong",null,{"children":"not"}]," store GPS coordinates or precise location."]}]
9:["$","h2",null,{"children":"2. How We Use Your Data"}]
a:["$","ul",null,{"children":[["$","li",null,{"children":"To notify you when someone scans your vehicle tag."}],["$","li",null,{"children":"To relay messages and calls without revealing either party's identity."}],["$","li",null,{"children":"To enforce rate limits and prevent abuse."}],["$","li",null,{"children":"To send you account-related emails (password resets, security alerts)."}]]}]
b:["$","p",null,{"children":["We ",["$","strong",null,{"children":"never"}]," sell your data, share it with advertisers, or use it for profiling."]}]
c:["$","h2",null,{"children":"3. Data Encryption"}]
d:["$","p",null,{"children":["Phone numbers are encrypted with AES-256-GCM using a server-side key. Passwords are hashed with ",["$","strong",null,{"children":"bcrypt"}]," (12 rounds). All traffic is encrypted over HTTPS/TLS."]}]
e:["$","h2",null,{"children":"4. Third-Party Services"}]
