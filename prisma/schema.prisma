generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(uuid())
  publicId             String         @unique @default(cuid())
  name                 String?
  email                String         @unique
  passwordHash         String
  phoneEncrypted       String?
  emailNotif           Boolean        @default(true)
  smsNotif             Boolean        @default(false)
  role                 String         @default("OWNER")
  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  plan                 String         @default("FREE")
  // Free Tag Grant
  freeTagGranted       Boolean        @default(false)
  freeTagGrantedAt     DateTime?
  freeTagTrialDays     Int            @default(30)
  freeTagGraceDays     Int            @default(5)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  assets               Asset[]
  familyMemberships    FamilyMember[] @relation("FamilyMember")
  familyOwned          FamilyMember[] @relation("FamilyOwner")
  notifications        Notification[]
  pushTokens           PushToken[]

  @@map("users")
}

model Asset {
  id                String      @id @default(uuid())
  publicId          String      @unique @default(cuid())
  ownerId           String
  type              String
  name              String
  subtitle          String?
  imageUrl          String?
  notes             String?
  isActive          Boolean     @default(true)
  towPreventionMode Boolean     @default(false)
  metadata          String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  owner             User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  autoReplies       AutoReply[]
  tags              Tag[]

  @@map("assets")
}

model Tag {
  id           String        @id @default(uuid())
  publicId     String        @unique @default(cuid())
  assetId      String
  shortCode    String        @unique
  nfcPayload   String?
  label        String?
  status       String        @default("ACTIVE")
  lockedReason String?       // "TRIAL_EXPIRED" | "ADMIN_LOCK" | null
  lockedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]
  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("tags")
}

model Interaction {
  id           String        @id @default(uuid())
  tagId        String
  actionType   String
  ipHash       String?
  userAgent    String?
  message      String?
  cityGuess    String?
  photoUrl     String?
  timestamp    DateTime      @default(now())
  chatThread   ChatThread?
  tag          Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  notification Notification?

  @@map("interactions")
}

model Notification {
  id            String      @id @default(uuid())
  userId        String
  interactionId String      @unique
  type          String
  title         String
  body          String
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AutoReply {
  id        String   @id @default(uuid())
  assetId   String
  label     String
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("auto_replies")
}

model FamilyMember {
  id        String   @id @default(uuid())
  ownerId   String
  memberId  String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  member    User     @relation("FamilyMember", fields: [memberId], references: [id], onDelete: Cascade)
  owner     User     @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, memberId])
  @@map("family_members")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model ChatThread {
  id            String        @id @default(uuid())
  interactionId String        @unique
  createdAt     DateTime      @default(now())
  messages      ChatMessage[]
  interaction   Interaction   @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@map("chat_threads")
}

model ChatMessage {
  id        String     @id @default(uuid())
  threadId  String
  sender    String
  text      String
  createdAt DateTime   @default(now())
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
